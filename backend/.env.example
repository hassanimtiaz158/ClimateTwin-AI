# ===========================================
# ClimateTwin AI — Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in values.
# For deployment, set these in your hosting platform's dashboard.

# ── Database ────────────────────────────────────────────────
# Local dev (SQLite):  sqlite+aiosqlite:///./climatetwin.db
# Render:              postgresql+asyncpg://user:pass@host:5432/dbname
# Railway:             postgresql+asyncpg://user:pass@host.railway.app:5432/railway
DATABASE_URL=sqlite+aiosqlite:///./climatetwin.db

# ── Security (REQUIRED in production) ──────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# ── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed origins, or JSON array.
# Examples:
#   http://localhost:3000,http://localhost:5173
#   ["https://climatetwin.vercel.app"]
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Server ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ── AI / ML ────────────────────────────────────────────────
MODEL_PATH=./models/trained
DATASET_PATH=./datasets
DEFAULT_FORECAST_YEARS=10

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── JWT (for future auth) ─────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# ── Redis (optional) ───────────────────────────────────────
USE_REDIS=false
REDIS_URL=redis://localhost:6379/0
